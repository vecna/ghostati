{
  "plugins": ["plugins/markdown"],
  "source": {
    "include": ["scripts"],
    "includePattern": ".+\\.js(doc|x)?$",
    "excludePattern": "(^|\\/|\\\\)_"
  },
  "opts": {
    "template": "node_modules/clean-jsdoc-theme/dist",
    "basePath": "/docs/",
    "destination": "./docs",
    "recurse": true,
    "readme": "./JSDOC_README.md"
  }
}
